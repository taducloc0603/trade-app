<Window x:Class="TradeDesktop.App.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Config"
        Height="540"
        Width="640"
        MinHeight="520"
        MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Config" FontSize="20" FontWeight="SemiBold" />

        <Border Grid.Row="2" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="10" Padding="14" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Sàn A"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#101828"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton Content="MT4" GroupName="ExchangeAPlatform" Margin="0,0,22,0" IsChecked="True" />
                        <RadioButton Content="MT5" GroupName="ExchangeAPlatform" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Map Name" FontWeight="SemiBold" />
                    <TextBox Grid.Column="1"
                             Margin="0,0,10,0"
                             Height="32"
                             VerticalContentAlignment="Center"
                             IsEnabled="{Binding AreMapNamesEnabled}"
                             Text="{Binding MapName1, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Content="Check"
                            Width="78"
                            Height="32"
                            IsEnabled="{Binding AreMapNamesEnabled}"
                            Command="{Binding CheckMap1Command}" />
                    <TextBlock Grid.Column="3"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Text="{Binding Map1CheckStatus}"
                               Foreground="#344054" />
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="CHART HWND A" FontWeight="SemiBold" />
                    <TextBox Grid.Column="1"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Text="{Binding ChartHwndA, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="TRADE HWND A" FontWeight="SemiBold" />
                    <TextBox Grid.Column="1"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Text="{Binding TradeHwndA, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Sàn B"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#101828"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton Content="MT4" GroupName="ExchangeBPlatform" Margin="0,0,22,0" IsChecked="True" />
                        <RadioButton Content="MT5" GroupName="ExchangeBPlatform" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Map Name" FontWeight="SemiBold" />
                    <TextBox Grid.Column="1"
                             Margin="0,0,10,0"
                             Height="32"
                             VerticalContentAlignment="Center"
                             IsEnabled="{Binding AreMapNamesEnabled}"
                             Text="{Binding MapName2, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Content="Check"
                            Width="78"
                            Height="32"
                            IsEnabled="{Binding AreMapNamesEnabled}"
                            Command="{Binding CheckMap2Command}" />
                    <TextBlock Grid.Column="3"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Text="{Binding Map2CheckStatus}"
                               Foreground="#344054" />
                </Grid>

                <Grid Grid.Row="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="CHART HWND B" FontWeight="SemiBold" />
                    <TextBox Grid.Column="1"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Text="{Binding ChartHwndB, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Grid Grid.Row="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="TRADE HWND B" FontWeight="SemiBold" />
                    <TextBox Grid.Column="1"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Text="{Binding TradeHwndB, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Margin="2,2,2,0">
            <TextBlock Foreground="#344054"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Text="{Binding LoadStatus}" />
            <TextBlock
                   Margin="0,4,0,0"
                   Foreground="#B42318"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Text="{Binding ErrorMessage}" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="92" Height="34" IsEnabled="{Binding CanSave}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>