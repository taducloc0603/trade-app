<Window x:Class="TradeDesktop.App.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Config"
        Height="390"
        Width="760"
        MinHeight="320"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Config" FontSize="20" FontWeight="SemiBold" />

        <Border Grid.Row="2" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="10" Padding="14" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Host Name" FontWeight="SemiBold" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,10,0" Height="32" VerticalContentAlignment="Center" IsReadOnly="True" Text="{Binding MachineHostName}" />
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Width="36"
                        Height="32"
                        FontSize="15"
                        ToolTip="Copy hostname"
                        Command="{Binding CopyHostNameCommand}">
                    <TextBlock Text="&#xE8C8;"
                               FontFamily="Segoe MDL2 Assssets"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
                <TextBlock Grid.Row="0" Grid.Column="3" Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding LoadStatus}" Foreground="#344054" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Map Name 1" FontWeight="SemiBold" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,10,0" Height="32" VerticalContentAlignment="Center" IsEnabled="{Binding AreMapNamesEnabled}" Text="{Binding MapName1, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="2" Grid.Column="2" Content="Check" Width="78" Height="32" IsEnabled="{Binding AreMapNamesEnabled}" Command="{Binding CheckMap1Command}" />
                <TextBlock Grid.Row="2" Grid.Column="3" Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding Map1CheckStatus}" Foreground="#344054" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Map Name 2" FontWeight="SemiBold" />
                <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,10,0" Height="32" VerticalContentAlignment="Center" IsEnabled="{Binding AreMapNamesEnabled}" Text="{Binding MapName2, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="4" Grid.Column="2" Content="Check" Width="78" Height="32" IsEnabled="{Binding AreMapNamesEnabled}" Command="{Binding CheckMap2Command}" />
                <TextBlock Grid.Row="4" Grid.Column="3" Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding Map2CheckStatus}" Foreground="#344054" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="2,2,2,0"
                   Foreground="#B42318"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Text="{Binding ErrorMessage}" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="92" Height="34" Margin="0,0,8,0" IsEnabled="{Binding CanSave}" Command="{Binding SaveCommand}" />
            <Button Content="Cancel" Width="92" Height="34" Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>