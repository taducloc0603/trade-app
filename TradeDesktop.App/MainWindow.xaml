<Window x:Class="TradeDesktop.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Trade Desktop Dashboard"
        Height="760"
        Width="760"
        MinHeight="720"
        MinWidth="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Dashboard" />

        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Connection" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" HorizontalAlignment="Right" Foreground="DarkBlue" FontWeight="SemiBold" />

                <TextBlock Grid.Row="2" Text="Bid" FontWeight="Bold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Bid}" HorizontalAlignment="Right" />

                <TextBlock Grid.Row="4" Text="Ask" FontWeight="Bold" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Ask}" HorizontalAlignment="Right" />

                <TextBlock Grid.Row="6" Text="Spread" FontWeight="Bold" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Spread}" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <Border Grid.Row="4" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Timestamp (UTC)" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="{Binding Timestamp}" HorizontalAlignment="Right" />

                <TextBlock Grid.Row="2" Text="Signal" FontWeight="Bold" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Signal}" HorizontalAlignment="Right" FontWeight="SemiBold" />

                <TextBlock Grid.Row="4" Text="Reason" FontWeight="Bold" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Reason}" HorizontalAlignment="Right" TextWrapping="Wrap" MaxWidth="320" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Start" Command="{Binding StartCommand}" Width="120" Margin="0,0,8,0" />
            <Button Content="Stop" Command="{Binding StopCommand}" Width="120" />
        </StackPanel>

        <Border Grid.Row="8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Tạo sàn (MapName check trước khi tạo)" FontSize="16" FontWeight="SemiBold" />

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#EEE" BorderThickness="1" CornerRadius="6" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Code (id record)" FontWeight="Bold" />

                            <TextBox Grid.Row="2"
                                     Text="{Binding ConfigCode, UpdateSourceTrigger=PropertyChanged}"
                                     Height="30"
                                     VerticalContentAlignment="Center" />

                            <Button Grid.Row="2"
                                    Grid.Column="2"
                                    Content="Check Code"
                                    Command="{Binding CheckConfigCodeCommand}"
                                    Width="120" />

                            <TextBlock Grid.Row="4"
                                       Grid.ColumnSpan="3"
                                       Foreground="DarkSlateBlue"
                                       Text="{Binding ConfigCodeCheckStatus}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#EEE" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Sàn 1" FontWeight="Bold" />

                                <TextBox Grid.Row="2"
                                         Text="{Binding Exchange1MapName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="30"
                                         VerticalContentAlignment="Center" />

                                <Button Grid.Row="4"
                                        Content="Check"
                                        Command="{Binding CheckExchange1MapNameCommand}"
                                        Width="100" />

                                <TextBlock Grid.Row="4"
                                           Margin="108,0,0,0"
                                           Text="{Binding Exchange1CheckStatus}"
                                           TextWrapping="Wrap"
                                           Foreground="DarkSlateBlue" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="#EEE" BorderThickness="1" CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Sàn 2" FontWeight="Bold" />

                                <TextBox Grid.Row="2"
                                         Text="{Binding Exchange2MapName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="30"
                                         VerticalContentAlignment="Center" />

                                <Button Grid.Row="4"
                                        Content="Check"
                                        Command="{Binding CheckExchange2MapNameCommand}"
                                        Width="100" />

                                <TextBlock Grid.Row="4"
                                           Margin="108,0,0,0"
                                           Text="{Binding Exchange2CheckStatus}"
                                           TextWrapping="Wrap"
                                           Foreground="DarkSlateBlue" />
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding UpdateStatus}" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="DarkGreen" />
                        <Button Content="Update sans"
                                Command="{Binding UpdateSansCommand}"
                                Width="140" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>