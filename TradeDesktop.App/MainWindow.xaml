<Window x:Class="TradeDesktop.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Trade Desktop Dashboard"
        Height="860"
        Width="1240"
        MinHeight="760"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6FA">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="270" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="12" Padding="16" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Dashboard" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#667085"
                               Text="{Binding RuntimeSummary}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#B42318"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding IsDbInlineDataVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding DbInlineData}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#B42318"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding IsConfigErrorVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding ConfigErrorMessage}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#F2F4F7"
                            BorderBrush="#D0D5DD"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,0"
                            Height="36"
                            Margin="0,0,8,0">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#344054"
                                   Text="{Binding TradingLogicStatusText, StringFormat=Trading Logic Status: {0}}" />
                    </Border>
                    <Button Content="Start"
                            Width="80"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding StartTradingLogicCommand}" />
                    <Button Content="Stop"
                            Width="80"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding StopTradingLogicCommand}" />
                    <TextBox Width="170"
                             Height="36"
                             Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             IsReadOnly="True"
                             Text="{Binding MachineHostName, Mode=OneWay}" />
                    <Button Content="Copy Host"
                            Width="100"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding CopyHostNameCommand}" />
                    <Button Content="Reconnect"
                            Width="120"
                            Height="36"
                            Margin="0,0,8,0"
                            Command="{Binding ReconnectConfigCommand}" />
                    <Button Content="Config"
                            Width="120"
                            Height="36"
                            Command="{Binding OpenConfigCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="12" Padding="16" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Thông số" FontSize="18" FontWeight="SemiBold" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Thông số" FontWeight="SemiBold" Foreground="#344054" />
                        <TextBlock Grid.Column="1" Text="{Binding ExchangeAHeader}" FontWeight="SemiBold" Foreground="#344054" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding ExchangeBHeader}" FontWeight="SemiBold" Foreground="#344054" HorizontalAlignment="Center" />

                        <Grid Grid.Row="2" Grid.ColumnSpan="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="0,7" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Symbol" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeASymbol}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBSymbol}" HorizontalAlignment="Center"/></Grid></Border>
                            <Border Grid.Row="1" Padding="0,7" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Bid" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeABid}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBBid}" HorizontalAlignment="Center"/></Grid></Border>
                            <Border Grid.Row="2" Padding="0,7" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Ask" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeAAsk}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBAsk}" HorizontalAlignment="Center"/></Grid></Border>
                            <Border Grid.Row="3" Padding="0,7" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Spread" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeASpread}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBSpread}" HorizontalAlignment="Center"/></Grid></Border>
                            <Border Grid.Row="4" Padding="0,7" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Latency(ms)" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeALatencyMs}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBLatencyMs}" HorizontalAlignment="Center"/></Grid></Border>
                            <Border Grid.Row="5" Padding="0,7" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="TPS" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeATps}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBTps}" HorizontalAlignment="Center"/></Grid></Border>
                            <Border Grid.Row="6" Padding="0,7" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Time" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeATime}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBTime}" HorizontalAlignment="Center"/></Grid></Border>
                            <Border Grid.Row="7" Padding="0,7" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Max Lat(ms)" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeAMaxLatMs}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBMaxLatMs}" HorizontalAlignment="Center"/></Grid></Border>
                            <Border Grid.Row="8" Padding="0,7" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Avg Lat(ms)" Foreground="#344054"/><TextBlock Grid.Column="1" Text="{Binding ExchangeAAvgLatMs}" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding ExchangeBAvgLatMs}" HorizontalAlignment="Center"/></Grid></Border>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="GAP BUY" FontWeight="SemiBold" Foreground="#344054" />
                        <TextBlock Grid.Column="2" Text="{Binding GapBuy}" Foreground="#101828" />

                        <TextBlock Grid.Column="4" Text="GAP SELL" FontWeight="SemiBold" Foreground="#344054" />
                        <TextBlock Grid.Column="6" Text="{Binding GapSell}" Foreground="#101828" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" CornerRadius="12" Padding="16" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Logs" FontSize="18" FontWeight="SemiBold" />
                        <Button Grid.Column="1" Content="Clear all" Width="90" Command="{Binding ClearLogsCommand}" />
                    </Grid>

                    <Border Grid.Row="2" BorderBrush="#EEF1F5" BorderThickness="1" CornerRadius="8" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding LogItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,6" BorderBrush="#EEF1F5" BorderThickness="0,0,0,1">
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#344054" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" CornerRadius="12" Padding="16" Background="White" BorderBrush="#E4E7EC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="3" Text="Thông tin lệnh" FontSize="18" FontWeight="SemiBold" />

                <Border Grid.Row="2" Grid.Column="0" BorderBrush="#EEF1F5" BorderThickness="1" CornerRadius="10" Background="#FAFBFC" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Khung lệnh trái" FontWeight="SemiBold" Foreground="#344054" />
                        <TextBlock Margin="0,8,0,0" Foreground="#667085" Text="Placeholder layout theo mockup." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="2" BorderBrush="#EEF1F5" BorderThickness="1" CornerRadius="10" Background="#FAFBFC" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Khung lệnh phải" FontWeight="SemiBold" Foreground="#344054" />
                        <TextBlock Margin="0,8,0,0" Foreground="#667085" Text="Placeholder layout theo mockup." />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.RowSpan="5"
                CornerRadius="12"
                Background="#99000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="White" CornerRadius="10" Padding="20" BorderBrush="#D0D5DD" BorderThickness="1">
                    <StackPanel Width="280">
                        <TextBlock Text="Đang tải..." FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                        <ProgressBar Margin="0,12,0,0" IsIndeterminate="True" Height="6" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding LoadingMessage}"
                                   Foreground="#475467"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>