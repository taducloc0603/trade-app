<UserControl x:Class="TradeDesktop.App.Views.OrderInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="220"
             d:DesignWidth="400">
    <Border BorderBrush="#EEF1F5"
            BorderThickness="1"
            CornerRadius="10"
            Background="#FAFBFC"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding PanelTitle}" FontWeight="SemiBold" Foreground="#344054" FontSize="14" />

            <TextBlock Grid.Row="2" Foreground="#475467" TextWrapping="Wrap">
                <Run Text="Map: " FontWeight="SemiBold" />
                <Run Text="{Binding TargetMapName}" />
            </TextBlock>

            <TextBlock Grid.Row="4" TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#B42318" />
                        <Setter Property="Text" Value="{Binding StatusMessage}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMapAvailable}" Value="True">
                                <Setter Property="Foreground" Value="#067647" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border Grid.Row="6"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="White"
                    Padding="10">
                <TextBlock Text="Chưa triển khai parse data"
                           Foreground="#667085"
                           FontStyle="Italic"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Border>
</UserControl>