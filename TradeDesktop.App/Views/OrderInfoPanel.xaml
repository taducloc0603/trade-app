<UserControl x:Class="TradeDesktop.App.Views.OrderInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="220"
             d:DesignWidth="400">
    <Border BorderBrush="#EEF1F5"
            BorderThickness="1"
            CornerRadius="10"
            Background="#FAFBFC"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding PanelTitle}" FontWeight="SemiBold" Foreground="#344054" FontSize="14" />

            <TextBlock Grid.Column="2" Foreground="#475467" TextWrapping="Wrap" VerticalAlignment="Center">
                <Run Text="Map: " FontWeight="SemiBold" />
                <Run Text="{Binding TargetMapName}" />
            </TextBlock>

            <TextBlock Grid.Column="4" TextWrapping="Wrap" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#B42318" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Text" Value="{Binding StatusMessage}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Foreground" Value="#475467" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                <Setter Property="Foreground" Value="#B54708" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMapAvailable}" Value="True">
                                <Setter Property="Foreground" Value="#067647" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Foreground" Value="#B42318" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border Grid.Row="2"
                    Grid.ColumnSpan="5"
                    BorderBrush="#E4E7EC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="White"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="95" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Records"
                               FontWeight="SemiBold"
                               Foreground="#344054" />

                    <Border Grid.Row="2"
                            BorderBrush="#EEF1F5"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="6"
                            Background="#FAFBFC">
                        <ListBox ItemsSource="{Binding Records}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#101828"
                                 FontFamily="Consolas"
                                 FontSize="11">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ItemsControl ItemsSource="{Binding LeftItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Width="90"
                                                   Text="{Binding Label}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#475467" />
                                        <TextBlock Text="{Binding Value}"
                                                   Foreground="#101828"
                                                   TextWrapping="Wrap" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Column="2" ItemsSource="{Binding RightItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Width="90"
                                                   Text="{Binding Label}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#475467" />
                                        <TextBlock Text="{Binding Value}"
                                                   Foreground="#101828"
                                                   TextWrapping="Wrap" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>