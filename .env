# Tên app dùng để đặt tên file .exe khi release
APP_NAME=TradeDesktop.App

# Version gốc: MAJOR.MINOR (ví dụ 1.0)
MAJOR=1
MINOR=0

# Số patch/build. Trong GitHub Actions thường lấy từ github.run_number
# Bạn có thể override thủ công khi build local
PATCH=0

# Version đầy đủ (nếu build local): MAJOR.MINOR.PATCH
VERSION=1.0.0

# Tên file output theo version
VERSIONED_EXE=TradeDesktop.App-1.0.0.exe

# Tên file output latest
LATEST_EXE=TradeDesktop.App-latest.exe

# Tag release Git (thường dạng v<version>)
TAG=v1.0.0

# Runtime target khi publish
RUNTIME=win-x64

# Dotnet SDK version dùng cho CI/build
DOTNET_VERSION=8.0.x